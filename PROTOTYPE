# COMMENT-Section 2 - Enumerations (Bin, Action, Region)
# Defines the machine's language using three Enum classes in order to prevent any errors caused by typos.
# Bin - The seven physical destination locations of refrigeration, freezer, dry storage, ambient bin, tropical bin, quarantine, and reject chute.
# Action - Four types of hardware control signals: divert the lane gate, stop the conveyor belt, activate the robotic arm, or open the reject trapdoor.
# Region - Five climate types of tropical, temperate, arid, arctic, and highland regions, used when determining how well the food type will preserve itself in the environment of its location.
# Used by: FoodProfile (Section 3) uses Bin and Region. SortDecision (Section 6) uses Bin and Action. Each scoring function uses the enumerations as return values or for comparisons.


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 2 — ENUMERATIONS
# ─────────────────────────────────────────────────────────────────────────────
# Why Enums instead of plain strings?
#   • IDE autocomplete catches typos at write-time, not runtime.
#   • Comparing Bin.FREEZER == "freezer_unit" works because Bin inherits str.
#   • Hardware driver code can switch on the enum value cleanly.

class Bin(str, Enum):
    """Physical destination bins/compartments on the sorting machine."""
    REFRIGERATION = "refrigeration_unit"    # 0–4 °C chilled storage
    FREEZER       = "freezer_unit"          # below -12 °C frozen storage
    DRY_STORAGE   = "dry_storage"           # room temp, low humidity shelf
    AMBIENT_BIN   = "ambient_bin"           # room temp general bin
    TROPICAL_BIN  = "tropical_bin"          # warm (13–25 °C) climate-controlled
    QUARANTINE    = "quarantine_bin"        # holds items the engine can't confidently classify
    REJECT        = "reject_chute"          # unsafe / expired — removed from food chain


class Action(str, Enum):
    """Physical commands sent to the machine's hardware drivers."""
    DIVERT_LANE  = "divert_lane"            # flip a pneumatic gate to redirect the belt lane
    CONVEYOR_STOP = "conveyor_stop"         # halt the belt so a precise pick can happen
    ROBOTIC_ARM  = "robotic_arm_trigger"    # trigger a full pick-and-place robotic cycle
    REJECT_CHUTE = "reject_chute_open"      # open a trapdoor and drop the item into reject


class Region(str, Enum):
    """Environmental/geographic profiles that affect long-term food suitability."""
    TROPICAL  = "tropical"                  # high humidity (>70 %), avg temp >25 °C
    TEMPERATE = "temperate"                 # moderate humidity, 10–20 °C average
    ARID      = "arid"                      # low humidity (<30 %), variable temperature
    ARCTIC    = "arctic"                    # very low temperature, low humidity
    HIGHLAND  = "highland"                  # high altitude, low atmospheric pressure


# COMMENT-Section 3 - Data Structures (TemperatureRange, FoodProfile)
#Defines two immutable data structures that describe food items in detail.
#TemperatureRange holds the minimum and maximum temperatures (min_c, max_c) in Celsius, and provides these functions:
#contains(temp) - Returns "True" if temp is between min and max (inclusive).
#is_borderline(temp, tolerance=2.0) - Returns "True" if temp is within 2 degrees of min/max. This tolerance is meant to represent real-world sensor noise and serves as the boundary point for the borderline scoring route.
#FoodProfile contains all of the information about a food item, including: TemperatureRange, shelf_life (in hours), a number from 1-10 describing perishability, tuple of allowed bins (preferred first), dict of region to score pairs, and boolean flag if food item must be placed in a bin by robotic arm.
#Used by: FOOD_CATALOG (Section 4) consists of multiple FoodProfiles. The scoring helpers in Section 7 read each field from FoodProfile.


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 3 — DATA STRUCTURES
# ─────────────────────────────────────────────────────────────────────────────

@dataclass(frozen=True)     # frozen=True makes the instance immutable (like a named tuple)
class TemperatureRange:
    """
    Represents the safe ambient storage temperature window for a food type.
    All temperatures are in degrees Celsius.
    """
    min_c: float            # lowest safe temperature (inclusive)
    max_c: float            # highest safe temperature (inclusive)

    def contains(self, temp: float) -> bool:
        """Return True if `temp` is within the safe window."""
        return self.min_c <= temp <= self.max_c

    def is_borderline(self, temp: float, tolerance: float = 2.0) -> bool:
        """
        Return True when the temperature is inside the safe range but
        within `tolerance` °C of either boundary.
        A borderline reading is not an immediate reject, but it signals
        the engine to prefer a safer secondary bin and reduce confidence.
        Default tolerance is ±2 °C — typical IR sensor measurement noise.
        """
        if not self.contains(temp):
            return False                    # outside range entirely — not borderline, just unsafe
        return (
            abs(temp - self.min_c) <= tolerance or
            abs(temp - self.max_c) <= tolerance
        )


@dataclass(frozen=True)     # frozen so catalog data can never be accidentally mutated at runtime
class FoodProfile:
    """
    Immutable descriptor for a class of food items.
    One FoodProfile exists per food type in FOOD_CATALOG.

    Fields
    ------
    name                : display label used in log output
    safe_temp_range     : the only temperatures where storage is safe
    shelf_life_hours    : hours to spoilage under ideal conditions
    perishability       : 1 (very stable) → 10 (spoils within hours)
                          used to compute routing urgency
    allowed_bins        : tuple of Bin values in preference order
                          (most preferred first)
    regional_scores     : dict mapping Region → float 0.0–1.0
                          1.0 = ideal conditions, 0.0 = unsuitable
    requires_robotic_arm: True for fragile or awkwardly shaped items
                          that cannot be passively diverted without damage
    """
    name:                 str
    safe_temp_range:      TemperatureRange
    shelf_life_hours:     float
    perishability:        int                   # must be 1–10
    allowed_bins:         tuple[Bin, ...]       # non-empty, ordered
    regional_scores:      dict[Region, float]   # all five Region keys expected
    requires_robotic_arm: bool = False          # default False — most items can be diverted


